<style>
    .auth-container {
        max-width: 500px;
        margin: 60px auto;
        background: #ffffff;
        border-radius: 25px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .auth-header {
        background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
        color: white;
        padding: 30px;
        text-align: center;
    }

    .auth-body {
        padding: 40px;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
        border: 2px solid #f1f3f5;
    }

    .test-notice {
        background: #fff4e5;
        border-left: 4px solid #ffa94d;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 25px;
        font-size: 0.85rem;
    }

    .btn-auth {
        background: #198754;
        color: white;
        border-radius: 50px;
        padding: 12px;
        font-weight: 700;
        width: 100%;
        border: none;
        transition: 0.3s;
    }

        .btn-auth:hover {
            background: #157347;
            transform: translateY(-2px);
        }
</style>

<div class="container">
    <div class="auth-container">
        <div class="auth-header">
            <h2 class="fw-bold mb-0"><i class="fa-solid fa-user-plus me-2"></i>Create Account</h2>
        </div>
        <div class="auth-body">
            <div class="test-notice">
                <p class="mb-1 text-dark fw-bold"><i class="fa-solid fa-shield-halved me-2"></i>Security Note:</p>
                <p class="mb-0 text-muted">Password must be at least 7 characters long. Complexity requirements are disabled for easy system testing.</p>
            </div>

            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Full Name</label>
                    <input type="text" name="FullName" class="form-control" placeholder="John Doe" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Email Address</label>
                    <input type="email" name="Email" class="form-control" placeholder="name@example.com" required />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Password</label>
                    <input type="password" name="Password" class="form-control" placeholder="Min. 7 characters" minlength="7" required />
                </div>
                <button type="submit" class="btn btn-auth mb-3 shadow-sm">Register</button>
            </form>
            <p class="text-center text-muted mb-0">Already have an account? <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Log In</a></p>
        </div>
    </div>
</div>