<style>
    .auth-container {
        max-width: 500px;
        margin: 80px auto;
        background: #ffffff;
        border-radius: 25px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .auth-header {
        background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
        color: white;
        padding: 30px;
        text-align: center;
    }

    .auth-body {
        padding: 40px;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
        border: 2px solid #f1f3f5;
    }

    .btn-login {
        background: #0d6efd;
        color: white;
        border-radius: 50px;
        padding: 12px;
        font-weight: 700;
        width: 100%;
        border: none;
        transition: 0.3s;
    }

        .btn-login:hover {
            background: #0b5ed7;
            transform: translateY(-2px);
        }
</style>

<div class="container">
    <div class="auth-container">
        <div class="auth-header">
            <h2 class="fw-bold mb-0"><i class="fa-solid fa-right-to-bracket me-2"></i>Welcome Back</h2>
        </div>
        <div class="auth-body">
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger rounded-pill px-4 py-2 small mb-4">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>@ViewBag.ErrorMessage
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Email Address</label>
                    <input type="email" name="email" class="form-control" placeholder="admin@gmail.com" required />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Password</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>
                <button type="submit" class="btn btn-login mb-3 shadow-sm">Login</button>
            </form>
            <p class="text-center text-muted mb-0">Don't have an account? <a asp-action="Register" class="text-primary fw-bold text-decoration-none">Register</a></p>
        </div>
    </div>
</div>