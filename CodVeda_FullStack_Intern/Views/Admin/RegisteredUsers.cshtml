@model IEnumerable<CodVeda_FullStack_Intern.Models.User>

@{
    ViewData["Title"] = "User Management";
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
        color: white;
        padding: 40px 0;
        border-radius: 20px;
        margin-bottom: 40px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .user-card {
        border: none;
        border-radius: 15px;
        background: #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transition: transform 0.2s;
    }

        .user-card:hover {
            transform: scale(1.02);
        }

    .user-icon {
        width: 50px;
        height: 50px;
        background: #e9ecef;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0d6efd;
        font-size: 1.2rem;
    }
</style>

<div class="container mt-4">
    <div class="admin-header">
        <div class="container px-4">
            <h1 class="fw-bold mb-0"><i class="fa-solid fa-users-gear me-3"></i>User Management</h1>
            <p class="opacity-75 mb-0">Monitor registered recruiters and users accessing the platform.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3">User Information</th>
                                    <th class="py-3">Email Address</th>
                                    <th class="py-3">Role Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <div class="user-icon me-3">
                                                    <i class="fa-solid fa-user"></i>
                                                </div>
                                                <span class="fw-bold text-dark">@user.FullName</span>
                                            </div>
                                        </td>
                                        <td class="py-3 text-secondary">
                                            <i class="fa-solid fa-envelope me-2 small"></i>@user.Email
                                        </td>
                                        <td class="py-3">
                                            @if (user.FullName == "System Admin")
                                            {
                                                <span class="badge bg-danger rounded-pill">Admin</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary rounded-pill">Registered User</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Books" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to Catalog
        </a>
    </div>
</div>