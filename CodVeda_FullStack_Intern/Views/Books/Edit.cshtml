@model CodVeda_FullStack_Intern.Models.Book

@{
    ViewData["Title"] = "Refine Masterpiece";
}

<style>
    .form-container {
        max-width: 800px;
        margin: 40px auto;
        background: #ffffff;
        border-radius: 25px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
    }
    .form-header {
        background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
        color: white;
        padding: 30px;
        text-align: center;
    }
    .form-body { padding: 40px; }
    .form-control {
        border-radius: 12px;
        padding: 12px 20px;
        border: 2px solid #f1f3f5;
        transition: all 0.3s ease;
    }
    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }
    .input-group-text {
        background: #f8f9fa;
        border: 2px solid #f1f3f5;
        border-right: none;
        border-radius: 12px 0 0 12px;
        color: #0d6efd;
    }
    .form-control-with-icon {
        border-left: none;
        border-radius: 0 12px 12px 0;
    }
    .btn-update {
        background: #0d6efd;
        color: white;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 700;
        border: none;
        width: 100%;
    }
</style>

<div class="container">
    <div class="form-container">
        <div class="form-header">
            <h2 class="fw-bold mb-1"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Book Details</h2>
            <p class="mb-0 opacity-75">Modify the information for "@Model.Title"</p>
        </div>

        <div class="form-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="IsHidden" />

                <div class="row">
                    <div class="col-md-12 mb-4">
                        <label asp-for="Title" class="form-label fw-bold text-secondary">Book Title</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-heading"></i></span>
                            <input asp-for="Title" class="form-control form-control-with-icon" required />
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Publisher" class="form-label fw-bold text-secondary">Publisher</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-building-columns"></i></span>
                            <input asp-for="Publisher" class="form-control form-control-with-icon" required />
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="PublishDate" class="form-label fw-bold text-secondary">Year</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-calendar-days"></i></span>
                            <input asp-for="PublishDate" class="form-control form-control-with-icon" required />
                        </div>
                    </div>

                    <div class="col-md-12 mb-4">
                        <label asp-for="ReadUrl" class="form-label fw-bold text-primary">Direct Reading Link (URL)</label>
                        <div class="input-group">
                            <span class="input-group-text border-primary text-primary"><i class="fa-solid fa-link"></i></span>
                            <input asp-for="ReadUrl" class="form-control form-control-with-icon border-primary" placeholder="Update reading link here..." />
                        </div>
                    </div>

                    <div class="col-md-12 mb-4">
                        <label asp-for="Summary" class="form-label fw-bold text-secondary">Summary</label>
                        <textarea asp-for="Summary" class="form-control" rows="4" required></textarea>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                    <button type="submit" class="btn btn-update shadow-sm">
                        <i class="fa-solid fa-floppy-disk me-2"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}