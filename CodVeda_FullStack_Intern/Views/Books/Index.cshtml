@model IEnumerable<CodVeda_FullStack_Intern.Models.Book>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Library Catalog";
    var userName = Context.Session.GetString("UserName");
    var isLoggedIn = userName != null;
    var isAdmin = userName == "System Admin";
}

<style>
    .catalog-header {
        background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
        color: white;
        padding: 40px 0;
        border-radius: 20px;
        margin-bottom: 40px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .book-card {
        border: none;
        border-radius: 20px;
        transition: all 0.3s ease;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

        .book-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

    .book-visual {
        height: 220px;
        background: linear-gradient(45deg, #f8f9fa 0%, #e9ecef 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        border-bottom: 1px solid #eee;
    }

    .book-icon-bg {
        font-size: 4rem;
        color: rgba(13, 110, 253, 0.2);
        margin-bottom: 10px;
    }

    .status-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        border-radius: 50px;
        padding: 5px 15px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .admin-controls {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 0 0 20px 20px;
    }

    .btn-action {
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .restricted-overlay {
        background: rgba(248, 249, 250, 0.9);
        padding: 20px;
        border-radius: 15px;
        border: 1px dashed #dee2e6;
    }

    .btn-read {
        transition: all 0.3s ease;
        font-weight: 700;
    }

        .btn-read:hover {
            transform: scale(1.05);
        }
</style>

<div class="container mt-4">
    <div class="catalog-header">
        <div class="container d-flex justify-content-between align-items-center px-4">
            <div>
                <h1 class="fw-bold mb-0"><i class="fa-solid fa-book-open-reader me-3"></i>Library Catalog</h1>
                <p class="opacity-75 mb-0">Experience world-class literature in your digital library.</p>
            </div>
            @if (isAdmin)
            {
                <div class="text-end">
                    <a asp-action="Create" class="btn btn-success btn-lg px-4 rounded-pill shadow">
                        <i class="fa-solid fa-plus me-2"></i> Add New Book
                    </a>
                    <div class="mt-2"><span class="badge bg-danger">ADMINISTRATOR VIEW</span></div>
                </div>
            }
        </div>
    </div>

    <div class="row g-4">
        @foreach (var book in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card book-card h-100 @(book.IsHidden ? "opacity-75" : "")">

                    <div class="book-visual">
                        <i class="fa-solid fa-book book-icon-bg"></i>

                        @if (isLoggedIn && !string.IsNullOrEmpty(book.ReadUrl))
                        {
                            <a href="@book.ReadUrl" target="_blank" class="btn btn-primary btn-sm rounded-pill px-4 btn-read shadow-sm">
                                <i class="fa-solid fa-book-open me-2"></i> Open Book
                            </a>
                        }

                        @if (book.IsHidden)
                        {
                            <span class="status-badge bg-warning text-dark">Hidden</span>
                        }
                        else
                        {
                            <span class="status-badge bg-primary text-white">Available</span>
                        }
                    </div>

                    <div class="card-body p-4">
                        <h4 class="fw-bold text-dark mb-3">@book.Title</h4>

                        @if (isLoggedIn)
                        {
                            <div class="mb-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fa-solid fa-building-columns text-primary me-2" style="width: 20px;"></i>
                                    <span class="text-secondary small">@book.Publisher</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fa-solid fa-calendar-days text-primary me-2" style="width: 20px;"></i>
                                    <span class="text-secondary small">@book.PublishDate</span>
                                </div>
                                <p class="text-muted" style="font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    @book.Summary
                                </p>
                            </div>
                        }
                        else
                        {
                            <div class="restricted-overlay text-center">
                                <i class="fa-solid fa-lock text-secondary mb-2 d-block fs-4"></i>
                                <p class="small text-secondary italic mb-3">Login to access full summary and reading links.</p>
                                <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-primary px-3 rounded-pill">Sign In</a>
                            </div>
                        }
                    </div>

                    @if (isAdmin && isLoggedIn)
                    {
                        <div class="admin-controls border-top d-flex gap-2 justify-content-center">
                            <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-warning btn-action">
                                <i class="fa-solid fa-pen-to-square"></i> Edit
                            </a>

                            <a asp-action="ToggleHide" asp-route-id="@book.Id" class="btn btn-sm btn-outline-secondary btn-action">
                                <i class="fa-solid @(book.IsHidden ? "fa-eye" : "fa-eye-slash")"></i> @(book.IsHidden ? "Unhide" : "Hide")
                            </a>

                            <form asp-action="Delete" asp-route-id="@book.Id" method="post" onsubmit="return confirm('Delete this book permanently?');" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger btn-action">
                                    <i class="fa-solid fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>